generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model LoveDex {
  id          String   @id @default(cuid())
  hash        String   @unique
  creatorName String
  partnerName String
  startDate   DateTime
  city        String?
  openingMessage String?
  mainQuestion String?
  message     String?
  emoji       String?
  theme       String   @default("rose")
  createdAt   DateTime @default(now())
}
